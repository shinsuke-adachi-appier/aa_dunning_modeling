# Copy to .env and fill. Do not commit .env.

# --- BigQuery (inference reads from embedded pipeline query; no BQ_SOURCE_TABLE) ---
BQ_PROJECT=
BQ_DATASET=
# BQ_SOURCE_TABLE=  # Not used: inference uses lib/bq_fetch.py ACTIVE_DUNNING_QUERY (subscription+transaction pipeline)
BQ_LOCATION=europe-west1
SCHEDULE_TABLE=production_dunning_schedule
TRIGGER_LOG_TABLE=dunning_retry_trigger_log
FEATURE_LOG_TABLE=dunning_inference_feature_log

# --- Model (inference job) ---
GCS_MODEL_URI=gs://YOUR_BUCKET/dunning/models/catboost_dunning_calibrated_20260301.joblib
# Or local path:
# DUNNING_MODEL_PATH=/path/to/catboost_dunning_calibrated_20260224.joblib
DUNNING_MODEL_VERSION=production

# --- Retrain job (Airflow/cron): optional ---
# Dates are relative to today by default (VAL_END=yesterday, etc.). Set GCS base and BQ for log.
# GCS_RETRAIN_BASE_URI=gs://YOUR_BUCKET/dunning/models   (model uploaded as {base}/{catboost_dunning_calibrated_SUFFIX.joblib})
# Or full object path: GCS_MODEL_URI=gs://YOUR_BUCKET/dunning/models/catboost_dunning_calibrated_production.joblib
# SUFFIX=20260315   (optional; default = today YYYYMMDD)
# BQ_PROJECT=       (required for training log export)
# BQ_DATASET=       (required for training log export)
# TRAINING_LOG_TABLE=dunning_training_log   (optional; default dunning_training_log)
# REPO_ROOT=/path/to/aa_dunning_modeling   (optional)

# --- Feature log (optional) ---
FEATURE_LOG_SAMPLE_PCT=1

# --- Trigger job: Chargebee (Pre-Flight + collect_payment). Required for trigger. ---
CHARGEBEE_SITE=aicreative
# CHARGEBEE_API_KEY=live_xxx   # Set in Cloud Run or mount from Secret Manager (do not commit)

# --- Trigger behaviour ---
RATE_LIMIT_PER_MIN=50
JITTER_MAX_SECONDS=1800
DRY_RUN=0
TRAFFIC_SPLIT_MODEL_PCT=100
# Velocity cap: no more than N retries per invoice in any rolling N-day window (avoids being flagged)
VELOCITY_CAP_DAYS=7
VELOCITY_CAP_MAX_RETRIES_7D=3
